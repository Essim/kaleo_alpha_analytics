{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "kaleotopia-alpha-analytics-visualizer",
  "main": "./src/worker.js",
  "compatibility_date": "2026-06-03",
  "assets": {
    "binding": "ASSETS",
    "directory": "./public",
    "not_found_handling": "single-page-application",
    "run_worker_first": true
  }
}
